{
  "name": "@tonic-ui/mcp",
  "version": "3.0.0-alpha.0",
  "description": "A Model Context Protocol (MCP) server for Tonic UI.",
  "bin": "./bin/cli.js",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "cross-env rollup --config rollup.config.mjs && yarn test-cli",
    "clean": "del build coverage dist",
    "lint": "eslint --ext .js,.ts,.mjs .",
    "pre-push": "bash -c 'echo -e \"=> \\e[1;33m$npm_package_name\\e[0m\"' && yarn run build && yarn run lint && yarn run test",
    "prepublishOnly": "yarn run build",
    "test": "cross-env NODE_ENV=test jest --maxWorkers=2 --passWithNoTests",
    "test-cli": "node scripts/prefix-output.js '[@tonic-ui/mcp] ' -- node --test tests/cli.test.mjs"
  },
  "keywords": [
    "mcp",
    "tonic-ui",
    "components"
  ],
  "author": "Tonic UI Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "morgan": "^1.10.1",
    "zod": "3.x"
  },
  "devDependencies": {
    "@babel/cli": "^7.0.0",
    "@babel/core": "^7.0.0",
    "@babel/eslint-parser": "^7.0.0",
    "@babel/eslint-plugin": "^7.0.0",
    "@babel/plugin-transform-runtime": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-typescript": "^7.24.7",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-typescript": "^11.0.0",
    "@trendmicro/babel-config": "^1.0.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "cross-env": "^7.0.0",
    "del-cli": "^5.0.0",
    "eslint": "^9.26.0",
    "eslint-config-trendmicro": "^4.4.1",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-extended": "^4.0.0",
    "rollup": "^3",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^1.1.1",
    "typescript": "^5.8.3"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.js",
      "<rootDir>/src/**/*.ts"
    ],
    "coverageReporters": [
      "lcov",
      "text",
      "html"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/build"
    ],
    "setupFiles": [],
    "setupFilesAfterEnv": [
      "<rootDir>/jest-setup.js"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/**/__tests__/**/*.test.js",
      "<rootDir>/**/__tests__/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
