{
  "private": true,
  "name": "@tonic-ui/react-docs",
  "description": "A documentation site for React Tonic UI component library.",
  "scripts": {
    "build": "bash -c '. ./tonic-ui.env && ./scripts/update-docs.sh && yarn build:mfe && cross-env NODE_ENV=production next build'",
    "clean": "del build coverage dist",
    "dev": "bash -c '. ./tonic-ui.env && ./scripts/update-docs.sh && concurrently \"yarn dev:mfe\" \"cross-env NODE_ENV=development next dev --hostname 0.0.0.0\"'",
    "lint": "eslint --ext .js,.jsx,.mjs .",
    "pre-push": "bash -c 'echo -e \"=> \\e[1;33m$npm_package_name\\e[0m\"' && yarn run lint && yarn run test",
    "start": "next start",
    "test": "cross-env NODE_ENV=test jest --maxWorkers=2 --passWithNoTests",
    "build:mfe": "yarn build:mfe-module-federation && yarn build:mfe-wujie",
    "build:mfe-wujie": "vite build --config mfe/wujie/apps/widget-updates/vite.config.mjs && vite build --config mfe/wujie/apps/widget-os/vite.config.mjs && vite build --config mfe/wujie/apps/inventory/vite.config.mjs && vite build --config mfe/wujie/host/vite.config.mjs",
    "build:mfe-module-federation": "vite build --config mfe/module-federation/remotes/widget-updates/vite.config.mjs && vite build --config mfe/module-federation/remotes/widget-os/vite.config.mjs && vite build --config mfe/module-federation/remotes/inventory/vite.config.mjs && vite build --config mfe/module-federation/shell/vite.config.mjs",
    "dev:mfe": "concurrently \"yarn dev:mfe-module-federation\" \"yarn dev:mfe-wujie\"",
    "dev:mfe-wujie": "concurrently \"vite build --watch --config mfe/wujie/apps/widget-updates/vite.config.mjs\" \"vite build --watch --config mfe/wujie/apps/widget-os/vite.config.mjs\" \"vite build --watch --config mfe/wujie/apps/inventory/vite.config.mjs\" \"vite build --watch --config mfe/wujie/host/vite.config.mjs\"",
    "dev:mfe-module-federation": "concurrently \"vite build --watch --config mfe/module-federation/remotes/widget-updates/vite.config.mjs\" \"vite build --watch --config mfe/module-federation/remotes/widget-os/vite.config.mjs\" \"vite build --watch --config mfe/module-federation/remotes/inventory/vite.config.mjs\" \"vite build --watch --config mfe/module-federation/shell/vite.config.mjs\""
  },
  "devDependencies": {
    "@babel/cli": "^7.0.0",
    "@babel/core": "^7.0.0",
    "@babel/eslint-parser": "^7.0.0",
    "@babel/eslint-plugin": "^7.0.0",
    "@babel/node": "^7.0.0",
    "@babel/plugin-transform-runtime": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/runtime": "^7.0.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@emotion/babel-plugin": "^11.13.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/jest": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mdx-js/loader": "^2.1.2",
    "@mdx-js/mdx": "^2.1.2",
    "@mdx-js/react": "^2.1.2",
    "@module-federation/vite": "^1.16.8",
    "@next/mdx": "^15.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.10",
    "@testing-library/jest-dom": "^6.0.0",
    "@tonic-ui/react": "workspace:^",
    "@tonic-ui/react-hooks": "workspace:^",
    "@tonic-ui/react-icons": "workspace:^",
    "@tonic-ui/utils": "workspace:^",
    "@trendmicro/babel-config": "^1.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "acorn": "^8.8.2",
    "algoliasearch": "^4.14.2",
    "boolean": "^3.2.0",
    "chance": "^1.1.12",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.0",
    "date-fns": "^4.4.0",
    "del-cli": "^5.0.0",
    "dotenv-flow": "^3.2.0",
    "echarts": "^5.5.0 || ^6.0.0",
    "ensure-type": "^1.5.1",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-trendmicro": "^4.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.0.0",
    "hastscript": "^8.0.0",
    "immer": "^10.1.1",
    "immutability-helper": "^3.1.1",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lodash": "^4.17.21",
    "lorem-ipsum": "^2.0.8",
    "lz-string": "^1.5.0",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-mdx-jsx": "^3.0.0",
    "micromark-extension-mdx-jsx": "^2.0.0",
    "next": "^15.5.14",
    "next-plugin-svgr": "^1.1.10",
    "node-emoji": "^2.1.0",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "15.x",
    "raw-loader": "^4.0.2",
    "react": "^18.3.0 || ^19.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.0 || ^19.0.0",
    "react-focus-lock": "^2.9.2",
    "react-frame-component": "^5.2.7",
    "react-instantsearch-core": "^7.5.0",
    "react-live": "^4.1.3",
    "react-movable": "^3.0.4",
    "react-table": "^7.8.0",
    "react-virtualized-auto-sizer": "^1.0.15",
    "react-virtuoso": "^4.12.0",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-slug": "^5.1.0",
    "remark-emoji": "^4.0.0",
    "remark-frontmatter": "^4.0.1",
    "remark-gfm": "^3.0.1",
    "remark-images": "^3.1.0",
    "remark-mdx-code-meta": "^2.0.0",
    "unist-util-visit": "^5.0.0",
    "uuid": "^14.0.0",
    "vite": "^5.4.0",
    "wujie-react": "2.1.0"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "<rootDir>/experiments/**/*.js"
    ],
    "coverageReporters": [
      "lcov",
      "text",
      "html"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/build"
    ],
    "setupFiles": [],
    "setupFilesAfterEnv": [
      "<rootDir>/jest-setup.js"
    ],
    "snapshotSerializers": [
      "@emotion/jest/serializer"
    ],
    "testEnvironment": "jsdom",
    "testMatch": [
      "<rootDir>/**/__tests__/**/*.test.js"
    ]
  }
}
